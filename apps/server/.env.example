# Copy to apps/server/.env and fill in. NEVER commit real keys (.env is gitignored).
# Each provider is optional — without a key, that stage falls back to the fake.
# The demo's dropdowns pick a provider per session; a stage only goes "real" if
# the selected provider's key is set below (else it uses the fake).

# --- ASR (speech-to-text) ---
# Deepgram (console.deepgram.com)
DEEPGRAM_API_KEY=
# OpenAI also provides streaming transcription (same key as GPT below).
# ElevenLabs Scribe v2 realtime also does ASR (same key as ElevenLabs TTS below).

# --- LLM ---
# Anthropic / Claude (console.anthropic.com)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6           # default: claude-haiku-4-5

# OpenAI — one key for GPT (LLM), streaming transcription (ASR), AND TTS (platform.openai.com)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini                     # GPT chat model
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# OPENAI_TTS_MODEL=gpt-4o-mini-tts             # or tts-1 (lower latency)
# OPENAI_TTS_VOICE=alloy

# Google Gemini (aistudio.google.com)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- TTS (text-to-speech) ---
# Cartesia (play.cartesia.ai)
CARTESIA_API_KEY=
# CARTESIA_VOICE_ID=

# ElevenLabs — one key for TTS AND Scribe v2 realtime ASR (elevenlabs.io)
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM     # default: Rachel (premade)
# ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
# ELEVENLABS_STT_MODEL=scribe_v2_realtime

# Server
PORT=8080

# Energy VAD threshold (0..1 RMS). Raise for noisy rooms; lower if not detected.
# VAD_THRESHOLD=0.03
