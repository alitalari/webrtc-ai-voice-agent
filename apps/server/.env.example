# Copy to apps/server/.env and fill in. NEVER commit real keys (.env is gitignored).
# Each provider is optional — without a key, that stage falls back to the fake.

# ASR — Deepgram (console.deepgram.com)
DEEPGRAM_API_KEY=

# LLM — Anthropic / Claude (console.anthropic.com)
ANTHROPIC_API_KEY=
# Optional: defaults to claude-haiku-4-5 (fast/cheap for voice).
# ANTHROPIC_MODEL=claude-sonnet-4-6

# TTS — Cartesia (play.cartesia.ai)
CARTESIA_API_KEY=
# Optional: a voice UUID from your Cartesia dashboard (a default is used otherwise).
# CARTESIA_VOICE_ID=

# Server
PORT=8080

# Energy VAD threshold (0..1 RMS). Raise for noisy rooms; lower if not detected.
# VAD_THRESHOLD=0.03
