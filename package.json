{
  "name": "ai-voice-sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Vendor-neutral real-time AI voice SDK — session layer, WebRTC transport, pluggable ASR/TTS/model providers.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/alitalari/rtc_sdk.git"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "tsc -b --clean",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
